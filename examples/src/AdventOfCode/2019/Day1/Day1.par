module Day1

import {
  @core/Char
  @core/Int
  @core/List
  @core/Nat
  @core/Result
  @core/String
  @basic/Console
  @basic/Os
}

// Helpers

dec FileRead : [String] Result<!, String>
def FileRead = [path]
  catch _ => .err! in
  let try reader = path->Os.Path->Os.OpenFile in
  let parser = String.ParserFromReader(reader) in
  let try contents = parser.remainder in
  .ok contents

dec StringLines : [String] List<String>
def StringLines = [string] String.Parser(string).begin.match(.repeat.non.char "\n", .one.char "\n").case {
  .end err => let ! = Result.Always(err) in .end!
  .fail attempt => .item(Result.Always(attempt.remainder)).end!
  .match(line, _) reader => .item(line) reader.loop
}

dec ListMap : [type a, type b, List<a>, box [a] b] List<b>
def ListMap = [type a, type b, list, f] list.begin.case {
  .end! => .end!
  .item(x) list => .item(f(x)) list.loop,
}

dec ListMapTry : [type a, type e, type b, List<box a>, box [a] Result<e, box b>] Result<e, List<b>>
def ListMapTry = [type a, type e, type b, list, f]
  let builder: List.Builder<box b> = List.Builder(type box b) in
  list.begin.case {
    .end! => .ok builder.build,
    .item(x) list =>
      f(x).case {
        .err err => let _ = builder.build in .err err,
        .ok y =>
          let builder = builder.add(y) in
          list.loop,
      },
  }

dec ListSum : [List<Nat>] Nat
def ListSum = [list]
  let result = 0 in
  list.begin.case {
    .end! => result,
    .item(n) list =>
      let result = result + n in
      list.loop,
  }

// AoC Logic

dec Fuel : [Nat] Nat
def Fuel = [mass] Nat.Max(0, mass / 3 - 2)

dec TotalFuel : [Nat] Nat
def TotalFuel = [mass]
  let totalMass = 0 in
  // number of steps should be less than mass, so this works as a bound
  Nat.Repeat(mass).begin.case {
    .end! => totalMass,
    .step rest =>
      let mass = Fuel(mass) in
      let totalMass = totalMass + mass in
      if {
        mass == 0 => totalMass,
        else => rest.loop,
      }
  }

dec Main : !
def Main = chan exit {
  let console = Console.Open

  FileRead("input01.txt").case {
    .err! => {
      console.print("could not read file")
      console.close
      exit!
    }
    .ok input => {}
  }

  let lines = StringLines(input)
  ListMapTry(type String, type !, type Nat, lines, box Nat.FromString).case {
    .err! => {
      console.print("invalid input")
      console.close
      exit!
    }
    .ok masses => {}
  }
  let result1 = ListSum(ListMap(type Nat, type Nat, masses, box Fuel))
  console.print(`Part 1: #{result1}`)
  let result2 = ListSum(ListMap(type Nat, type Nat, masses, box TotalFuel))
  console.print(`Part 2: #{result2}`)
  console.close
  exit!
}
