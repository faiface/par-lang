module Factorial

import @core/Test
import @core/Nat

// Simple factorial with mutable state
def SimpleFactorial: [Nat] Nat = [n]
  let result = 1 in
  let counter = 1 in
  Nat.Repeat(n).begin.case {
    .end! => result,
    .step s => do {
      result *= counter
      counter += 1
    } in s.loop,
  }

def TestFactorial: [Test] ! = [test] do {
  test.assert("Factorial of 5 is 120", SimpleFactorial(5) == 120)
} in !
