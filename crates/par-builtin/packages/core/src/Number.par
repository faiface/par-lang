export module Number

export {
  dec Zero : [type a: number] a

  dec Add : <a: number>[(a) a] a

  dec Sub : <a: signed>[(a) a] a

  dec Mul : <a: number>[(a) a] a

  dec Div : <a: number>[(a) a] a

  dec Neg : <a: signed>[a] a
}

dec Zero_ : [type a: number, !] a

def Zero_ = external

def Zero = [type a: number] Zero_(type a, !)

def Add = external

def Sub = external

def Mul = external

def Div = external

def Neg = external
