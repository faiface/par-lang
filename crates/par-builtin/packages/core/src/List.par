// Finite list types and list combinators.
//
// ```par
// let xs = *(1, 2, 3)
// xs->List.Map(type Int, box [n] Int.Mul(n, 2))
// ```
export module List

import {
  Bool
  Nat
  Option
  Result
}

export {
  // A finite, ordered sequence of values.
  //
  // ```par
  // *(1, 2, 3)  // syntax sugar for .item(1) .item(2) .item(3) .end!
  // ```
  type List<a> = recursive either {
    .end!,
    .item(a) self,
  }

  // Incrementally constructs a list.
  type Builder<a> = iterative choice {
    .add(a) => self,
    .build => List<a>,
  }

  // A list that ends with `Result<e, !>` instead of `!`.
  // Use it for streams that may finish with an error.
  type Fallible<e, a> = recursive either {
    .end Result<e, !>,
    .item(a) self,
  }

  // Creates a new list `Builder`.
  dec Builder : [type a] Builder<a>

  // Applies `f` to each element of a list.
  //
  // ```par
  // {*(1, 2, 3)}->List.Map(type Int, box [n] Int.Mul(n, 2))
  // // = *(2, 4, 6)
  // ```
  dec Map : <a>[List<a>] [type b, box [a] b] List<b>

  // Applies `f` to each element and concatenates the resulting lists.
  dec FlatMap : <a>[List<a>] [type b, box [a] List<b>] List<b>

  // Keeps the elements for which the predicate returns `.true!`.
  dec Filter : <a: box>[List<a>] [box [a] Bool] List<a>

  // Folds a list from left to right.
  //
  // ```par
  // {*(1, 2, 3)}->List.Fold(0, box [sum, n] Nat.Add(sum, n))
  // // = 6
  // ```
  dec Fold : <a>[List<a>] <r>[r] [box [r, a] r] r

  // Returns the number of elements in a list.
  dec Length : <a: box>[List<a>] Nat

  // Flattens a list of lists into a single list.
  dec Concat : <a>[List<List<a>>] List<a>

  // Yields all items from a source list onto a destination channel, consuming the source.
  dec Copy : <a>[dual List<a>] [List<a>] dual List<a>

  // Zips two lists into a list of pairs. Stops at the shorter list.
  dec Zip : <a: box>[List<a>] <b: box>[List<b>] List<(a) b>

  // Splits a list of pairs into a pair of lists.
  dec Unzip : <a, b>[List<(a) b>] (List<a>) List<b>

  // Returns `.true!` if the predicate holds for all elements.
  // Short-circuits on the first `.false!`.
  dec All : <a: box>[List<a>] [box [a] Bool] Bool

  // Returns `.true!` if the predicate holds for at least one element.
  // Short-circuits on the first `.true!`.
  dec Any : <a: box>[List<a>] [box [a] Bool] Bool

  // Returns the first `n` elements of a list.
  dec Take : <a: box>[List<a>] [Nat] List<a>

  // Drops the first `n` elements of a list and returns the rest.
  dec Drop : <a: box>[List<a>] [Nat] List<a>

  // Sorts a list in ascending data order. Equal keys keep their original order.
  dec Sort : <a: data>[List<a>] List<a>

  // Sorts a list in descending data order. Equal keys keep their original order.
  dec SortDesc : <a: data>[List<a>] List<a>

  // Sorts a non-linear list by an extracted data key.
  dec SortBy : <a: box>[List<a>] [type k: data, box [a] k] List<a>

  // Sorts a non-linear list by an extracted data key in descending order.
  dec SortDescBy : <a: box>[List<a>] [type k: data, box [a] k] List<a>

  // Sorts a linear list by a function that returns both the key and the item.
  dec SortLinearBy : <a>[List<a>] [type k: data, box [a] (k) a] List<a>

  // Sorts a linear list by a key in descending order.
  dec SortLinearDescBy : <a>[List<a>] [type k: data, box [a] (k) a] List<a>
}

def Builder = [type a]
  let append: [List<a>] List<a> = [xs] xs
  in begin case {
    .add(x) => let append = [xs: List<a>] append(.item(x) xs) in loop,
    .build => append(.end!),
  }

def Map = <a>[list] [type b, f] list.begin.case {
  .end! => .end!
  .item(v) list => .item(f(v)) list.loop,
}

def FlatMap = <a>[list] [type b, f] list.begin.case {
  .end! => .end!,
  .item(v) list => f(v).begin@flat.case {
    .end! => list.loop,
    .item(v) flat => .item(v) flat.loop@flat,
  },
}

def Filter = <a: box>[list] [f] list.begin.case {
  .end! => .end!,
  .item(v) list => f(v).case {
    .true! => .item(v) list.loop,
    .false! => list.loop,
  },
}

def Fold = <a>[list] <r>[result] [f] list.begin.case {
  .end! => result,
  .item(v) list => let result = f(result, v) in list.loop,
}

def Length = <a: box>[list]
  let len = 0 in
  list.begin.case {
    .end! => len,
    .item(_) list => do { len->Nat.Add(1) } in list.loop,
  }

def Concat = <a>[lists] chan yield {
  lists.begin.case {
    .item(list) => {
      yield->Copy(list)
      lists.loop
    }
    .end! => {
      yield.end!
    }
  }
}

def Copy = <a>[dst] [src] do {
  src.begin.case {
    .end! => {},
    .item(v) src => {
      dst.item(v)
      src.loop
    },
  }
} in dst

def Zip = <a: box>[list1] <b: box>[list2] chan yield {
  list1.begin.case {
    .end! => { yield.end! },
    .item(v1) list1 => {
      list2.case {
        .end! => { yield.end! },
        .item(v2) list2 => {
          yield.item((v1) v2)
          list1.loop
        },
      }
    },
  }
}

def Unzip = <a, b>[list] list.begin.case {
  .end! => (.end!) .end!,
  .item((x) y) xys => do {
    let (xs) ys = xys.loop
  } in (.item(x) xs) .item(y) ys
}

def All = <a: box>[list] [f]
  list.begin.case {
    .end! => .true!,
    .item(v) list => f(v).case {
      .true! => list.loop,
      .false! => .false!,
    },
  }

def Any = <a: box>[list] [f] {not list->All(box [v] {not f(v)})}

def Take = <a: box>[list] [n]
  Nat.Repeat(n).begin.case {
    .end! => .end!,
    .step next => list.case {
      .end! => .end!
      .item(v) list => .item(v) next.loop,
    }
  }

def Drop = <a: box>[list] [n]
  Nat.Repeat(n).begin.case {
    .end! => list,
    .step next => list.case {
      .end! => .end!,
      .item(_) list => next.loop,
    },
  }

def Sort = external

def SortDesc = external

def SortBy = external

def SortDescBy = external

def SortLinearBy = external

def SortLinearDescBy = external
