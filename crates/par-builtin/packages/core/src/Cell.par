// Shared cells.
export module Cell

export {
  // A shared cell containing a value.
  //
  // - `.end` — release the cell.
  // - `.split` — create another handle to the same cell.
  // - `.take` — remove the current value and continue by choosing `.put`.
  type Cell<a> = iterative choice {
    .end => ?,
    .split(dual self) => self,
    .take => (a) choice {
      .put(a) => self,
    }
  }

  // Serves a value through a `Cell`.
  // Returns the final value when all clients are done.
  dec Share : <a>[a] [dual Cell<a>] a
}

def Share = <a>[value] [client] poll(client) {
  session => session.case {
    .end! => submit(),
    .split(client1) client2 => submit(client1, client2),
    .take session => session(value).case {
      .put(value) client => submit(client),
    }
  }
  else => value,
}
