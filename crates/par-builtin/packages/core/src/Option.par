// `Option<a>` models an optional value.
//
// - `.ok value` means a value is present.
// - `.err!` means there is no value.
//
// It is a thin alias over `Result<!, a>`, so it is best when you want
// **absence** rather than a richer error payload.
export module Option

import {
  Result
}

export {
  // An `Option` is a `Result` where the error type is `!` (unit),
  // meaning it either holds a value (`.ok`) or nothing (`.err!`).
  type Option<a> = Result<!, a>
}
